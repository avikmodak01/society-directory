{
  "rules": {
    ".read":  false,
    ".write": false,

    "admins": {
      ".read":  false,
      ".write": false,
      "$uid": {
        ".read": "auth != null && auth.uid == $uid"
      }
    },

    "contacts": {
      "approved": {
        ".read": true,
        ".indexOn": ["phone"],
        "$contactId": {
          ".write": "
            (!data.exists() && newData.exists()) ||
            (data.exists() && !newData.exists() && auth != null && root.child('admins').child(auth.uid).val() == true)
          ",
          ".validate": "
            !newData.exists() ||
            (
              newData.hasChildren(['name','phone','category','createdAt']) &&
              newData.child('name').isString() &&
              newData.child('name').val().length > 0 &&
              newData.child('name').val().length <= 100 &&
              newData.child('phone').isString() &&
              newData.child('phone').val().length == 10 &&
              newData.child('category').isString() &&
              newData.child('createdAt').isNumber() &&
              (!newData.hasChild('description') || (newData.child('description').isString() && newData.child('description').val().length <= 120))
            )
          ",
          "ratings": {
            "$deviceId": {
              ".write": true,
              ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 5"
            }
          }
        }
      },
      "pending": {
        ".read":  "auth != null && root.child('admins').child(auth.uid).val() == true",
        ".write": "auth != null && root.child('admins').child(auth.uid).val() == true"
      }
    },

    "ratings": {
      ".read": "auth != null && root.child('admins').child(auth.uid).val() == true",
      "$contactId": {
        ".write": "auth != null && root.child('admins').child(auth.uid).val() == true",
        "$deviceId": {
          ".write": true,
          ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 5"
        }
      }
    },

    "reviews": {
      ".read": true,
      "$contactId": {
        ".write": "auth != null && root.child('admins').child(auth.uid).val() == true",
        "$reviewId": {
          ".write": "!data.exists() && newData.exists()",
          ".validate": "
            newData.hasChildren(['text','createdAt']) &&
            newData.child('text').isString() &&
            newData.child('text').val().length > 0 &&
            newData.child('text').val().length <= 100 &&
            newData.child('createdAt').isNumber()
          "
        }
      }
    },

    "pending_deletions": {
      ".read": "auth != null && root.child('admins').child(auth.uid).val() == true",
      "$id": {
        ".write": "
          (!data.exists() && newData.exists()) ||
          (data.exists() && !newData.exists() && auth != null && root.child('admins').child(auth.uid).val() == true)
        ",
        ".validate": "
          !newData.exists() ||
          (
            newData.hasChildren(['contactId','contactName','requestedAt']) &&
            newData.child('contactId').isString() &&
            newData.child('contactName').isString() &&
            newData.child('requestedAt').isNumber()
          )
        "
      }
    },

    "categories": {
      ".read": true,
      "$id": {
        ".write": "auth != null && root.child('admins').child(auth.uid).val() == true",
        ".validate": "
          !newData.exists() ||
          (
            newData.hasChildren(['label','emoji','color','bg']) &&
            newData.child('label').isString() &&
            newData.child('label').val().length > 0 &&
            newData.child('label').val().length <= 50 &&
            newData.child('emoji').isString() &&
            newData.child('color').isString() &&
            newData.child('bg').isString()
          )
        "
      }
    }
  }
}
